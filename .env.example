# APEX Configuration — copy to .env and fill in

# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ODDS_API_KEY=your_odds_api_key_here

# Polymarket (only needed for live mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# Bot identity
BOT_NAME=APEX

# Mode — paper trading is DEFAULT
DRY_RUN=true

# Bankroll
STARTING_BANKROLL=20.0

# Risk limits
MAX_POSITION_PCT=0.15
MAX_SPORT_EXPOSURE_PCT=0.40
DAILY_DRAWDOWN_PCT=0.20
ROLLING_DRAWDOWN_PCT=0.35
MAX_CONSECUTIVE_LOSSES=5
MIN_PROFIT_THRESHOLD=1.0

# Kelly fractions
KELLY_FRACTION=0.25
KELLY_FRACTION_SMALL_BANKROLL=0.33
SMALL_BANKROLL_THRESHOLD=50.0

# Data freshness (seconds)
ODDS_MAX_AGE=300
POLYMARKET_MAX_AGE=120
INJURY_MAX_AGE=600

# Strategy toggles
STRATEGY_FAIR_VALUE=true
STRATEGY_BOOK_DIVERGENCE=true
STRATEGY_NEWS_SHOCK=true
STRATEGY_INJURY_REPRICE=true
STRATEGY_STEAM_MOVE=true
STRATEGY_CONTRARIAN=true
STRATEGY_ORDERBOOK_SCALP=false
STRATEGY_PRELOCK_REPRICE=true
STRATEGY_COMPLEMENT_ARB=true
STRATEGY_SHARP_FOLLOW=true
STRATEGY_MOMENTUM=true

# Scheduling intervals (seconds)
MARKET_SCAN_INTERVAL=120
STRATEGY_CYCLE_INTERVAL=60
FILL_POLL_INTERVAL=15
RESOLUTION_POLL_INTERVAL=60
RESULTS_TRACKER_INTERVAL=600
HEALTH_CHECK_INTERVAL=300
STOP_MANAGER_INTERVAL=15

# Telegram authorization (comma-separated numeric user IDs)
TELEGRAM_AUTHORIZED_USERS=

# Mapping
MIN_MAPPING_CONFIDENCE=0.70

# Database
DB_PATH=apex.db

# Logging
LOG_LEVEL=INFO
